# Database
DATABASE_URL="postgresql://user:password@localhost:5432/batik_heritage?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Stripe (Future)
STRIPE_SECRET_KEY="your-stripe-secret-key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"

# Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Batikora"

# ==================== Shipping Carriers ====================

# DHL Express (MyDHL API)
# Register at: https://developer.dhl.com
DHL_API_KEY="your-dhl-api-key"
DHL_API_SECRET="your-dhl-api-secret"
DHL_ACCOUNT_NUMBER="your-dhl-account-number"
DHL_MODE="test" # "test" or "production"

# RajaOngkir (JNE + Pos Indonesia)
# Register at: https://rajaongkir.com
RAJAONGKIR_API_KEY="your-rajaongkir-api-key"
RAJAONGKIR_TYPE="starter" # "starter" (free), "basic", or "pro"

# Store Origin (for shipping calculations)
SHIPPING_ORIGIN_CITY="Yogyakarta"
SHIPPING_ORIGIN_CITY_ID="501"
SHIPPING_ORIGIN_POSTAL_CODE="55000"
SHIPPING_ORIGIN_COUNTRY="ID"

